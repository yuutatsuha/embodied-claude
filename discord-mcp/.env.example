# Discord bot token — Developer Portal -> your app -> Bot -> Reset Token
DISCORD_BOT_TOKEN=

# Default channel ID (enable Developer Mode, right-click channel -> Copy Channel ID).
# Used when send_message / read_recent are called without an explicit channel_id.
DISCORD_CHANNEL_ID=

# Optional: guild (server) ID, used only to build clickable message links.
# If omitted, links fall back to the /@me form.
DISCORD_GUILD_ID=
